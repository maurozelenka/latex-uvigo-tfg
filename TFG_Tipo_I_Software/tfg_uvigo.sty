% Codificación e lingua
% IMPORTANTE: O último idioma na lista de Babel é o principal do documento.
%   - Para redactar en GALEGO (por defecto): \usepackage[spanish,galician]{babel}
%   - Para redactar en CASTELÁN: cambiar a  \usepackage[galician,spanish]{babel}
%     e descomentar as redefinicións de \captionsspanish máis abaixo.
\usepackage[spanish,galician]{babel}
\addto\captionsgalician{
  \renewcommand{\contentsname}{Índice Xeral}
  \renewcommand{\listfigurename}{Índice de Ilustracións}
  \renewcommand{\listtablename}{Índice de Táboas}
}
% Descomentar estas liñas se o idioma principal é o Castelán:
% \addto\captionsspanish{
